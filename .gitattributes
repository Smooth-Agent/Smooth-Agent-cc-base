# Force LF on files that run inside Linux containers.
* text=auto eol=lf

*.sh        text eol=lf
Dockerfile  text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf

# Binary artifacts (none currently, but reserved)
*.png       binary
*.jpg       binary
*.tar       binary
*.tar.gz    binary
